{
  "name": "@app/preload",
  "files": [
    "assets/**",
    "dist/**",
    "package.json"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/_virtual_browser.mjs"
