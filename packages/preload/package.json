      "types": "./src/exposed.d.ts",
      "default": "./dist/exposed.mjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-store": "^11.0.2"
  },
  "devDependencies": {
    "@app/electron-versions": "workspace:*",
    "mlly": "^1.8.2",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
